# -----------------------------------------------------------------------------
# Core Neo4j configuration
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_DATABASE=neo4j
NEO4J_SANDBOX_URI=
NEO4J_SANDBOX_USER=neo4j
NEO4J_SANDBOX_PASSWORD=
NEO4J_SANDBOX_DATABASE=neo4j

# -----------------------------------------------------------------------------
# Deliberation API runtime configuration
# -----------------------------------------------------------------------------
DELIBERATION_API_URL=http://localhost:8010
DELIBERATION_API_FALLBACK_URL=https://fs-stns.onrender.com
DELIBERATION_API_TIMEOUT_S=70

# Deliberation API DB mode (local|sandbox) + optional explicit override
DELIBERATION_DB_MODE=local
DELIBERATION_NEO4J_URI=
DELIBERATION_NEO4J_USER=
DELIBERATION_NEO4J_PASSWORD=
DELIBERATION_NEO4J_DATABASE=

# Optional: skip Neo4j init in smoke tests
DELIBERATION_SKIP_DB_INIT=false

# Optional Redis cache for deliberation API
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=30

# -----------------------------------------------------------------------------
# Access controls
# -----------------------------------------------------------------------------
PUBLIC_ONLY=false
SUPPORTER_ACCESS_CODE=

# -----------------------------------------------------------------------------
# Integrations and notifications
# -----------------------------------------------------------------------------
FEEDBACK_EMAIL_TO=
FEEDBACK_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
WHATSAPP_GROUP_WEBHOOK_URL=
WHATSAPP_GROUP_WEBHOOK_TOKEN=
SLACK_WEBHOOK_URL=
SLACK_USERNAME=Freedom Square CRM
DUE_DILIGENCE_APP_URL=

# -----------------------------------------------------------------------------
# Observability (Sentry + logging)
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
SENTRY_DSN=
CRM_SENTRY_DSN=
DELIBERATION_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ENABLE_STREAMLIT=true
APP_RELEASE=local-dev

# -----------------------------------------------------------------------------
# Agent Chain (console.py)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_S=90

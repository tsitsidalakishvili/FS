# --- App config (existing app.py) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_DATABASE=neo4j
NEO4J_SANDBOX_URI=
NEO4J_SANDBOX_USER=neo4j
NEO4J_SANDBOX_PASSWORD=
NEO4J_SANDBOX_DATABASE=neo4j

# Deliberation API (FastAPI) URL used by app.py
DELIBERATION_API_URL=http://localhost:8010
# Increase if backend is on free Render and can cold-start
DELIBERATION_API_TIMEOUT_S=70

# Deliberation API DB config (optional)
DELIBERATION_DB_MODE=local
DELIBERATION_NEO4J_URI=
DELIBERATION_NEO4J_USER=
DELIBERATION_NEO4J_PASSWORD=
DELIBERATION_NEO4J_DATABASE=

# Optional access gating for app.py
PUBLIC_ONLY=false
SUPPORTER_ACCESS_CODE=

# Feedback email (optional)
FEEDBACK_EMAIL_TO=
FEEDBACK_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- Agent Chain (console.py) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_S=90

# Optional Slack notifications for agent progress
SLACK_WEBHOOK_URL=
SLACK_USERNAME=agent-chain

